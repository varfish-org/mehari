{
  "packages": {
    "mehari": {
      "release-type": "rust",
      "include-component-in-tag": false
    },
    "mehari-python": {
      "release-type": "rust",
      "include-component-in-tag": false,
      "extra-files": [
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.project.version"
        }
      ]
    }
  },
  "plugins": [
    "rust-workspace",
    {
      "type": "linked-versions",
      "groupName": "mehari-sync",
      "components": [
        "mehari",
        "mehari-python"
      ]
    }
  ]
}
